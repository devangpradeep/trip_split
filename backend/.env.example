# Local development only. Do not commit your real .env.

# App
RAILS_ENV=development
FRONTEND_APP_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
FORCE_SSL=false

# Auth
DEVISE_JWT_SECRET_KEY=replace_with_a_long_random_string
DEVISE_JWT_EXPIRATION_HOURS=24

# Active Record Encryption
# Generate real values with: bin/rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=replace_with_active_record_encryption_primary_key
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=replace_with_active_record_encryption_deterministic_key
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=replace_with_active_record_encryption_key_derivation_salt

# Database (local Postgres)
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_HOST=localhost

# Optional: use a full connection URL (Neon/local/etc)
# DATABASE_URL=postgresql://user:password@host:5432/database_name
