.ruby-lsp/

# Backend (Rails)
/backend/.bundle
/backend/.env
/backend/.env.*
!/backend/.env.example

/backend/log/
/backend/tmp/
/backend/storage/
/backend/**/.keep

/backend/config/master.key

# Frontend (Vite/React)
/frontend/logs
/frontend/*.log
/frontend/npm-debug.log*
/frontend/yarn-debug.log*
/frontend/yarn-error.log*
/frontend/pnpm-debug.log*
/frontend/lerna-debug.log*

/frontend/node_modules
/frontend/dist
/frontend/dist-ssr
/frontend/*.local

/frontend/.vscode/*
!/frontend/.vscode/extensions.json
/frontend/.idea
/frontend/.DS_Store
/frontend/*.suo
/frontend/*.ntvs*
/frontend/*.njsproj
/frontend/*.sln
/frontend/*.sw?
